# このファイルを .env という名前でコピーして、値を書き換えてください

# 検索対象の共有フォルダ（Windowsの共有フォルダは \\サーバー名\共有名 の形式でOK）
SEARCH_FOLDER=\\server\share\documents

# Anthropic APIキー（console.anthropic.com → API Keys → Create Key）
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# --- 以下は任意（省略可） ---
# 使用モデル
#CLAUDE_MODEL=claude-sonnet-4-6
# 待ち受けポート
#PORT=5000
# AIに渡す候補ファイル数（多いほど精度↑・料金↑）
#MAX_FILES_TO_AI=5
